{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "constellation",
  "compatibility_date": "2026-05-20",
  "main": "worker/index.ts",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
